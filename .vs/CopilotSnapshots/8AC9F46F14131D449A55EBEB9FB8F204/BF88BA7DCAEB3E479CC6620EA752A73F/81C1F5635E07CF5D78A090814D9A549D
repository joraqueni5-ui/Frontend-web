<template>
  <div class="login-wrap">
    <div class="card">
      <div class="brand-pill">UNIFRANZ</div>
      <h1 class="title">Bienvenido</h1>

      <label>Usuario</label>
      <input v-model="email" type="email" placeholder="ejemplo@unifranz.edu.bo" />

      <label>Contraseña</label>
      <input v-model="password" type="password" placeholder="••••••••" />

      <button class="primary" :disabled="loading" @click="requestOtp">
        {{ loading ? 'Enviando…' : 'INGRESAR' }}
      </button>

      <p v-if="error" class="error">{{ error }}</p>
    </div>
  </div>
</template>

<script setup>
import { ref } from 'vue'
import { useRouter } from 'vue-router'

const router = useRouter()
const email = ref('')
const password = ref('')
const loading = ref(false)
const error = ref('')

async function requestOtp(){
  error.value = ''
  if(!email.value) { error.value = 'Ingresa tu correo institucional.'; return }
  loading.value = true
  try{
    await fetch('/api/auth/request-otp',{
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ email: email.value, password: password.value })
    })
    // siempre redirigimos a OTP; el backend debe enviar correo
    router.push({ name:'Otp' , query:{ email: email.value } })
  }catch(e){
    error.value = 'No se pudo enviar OTP.'
  }finally{ loading.value = false }
}
</script>

